// Prisma schema for the agentic marketplace.
// PostgreSQL is the backing store for local development and production-like runs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products      Product[]
  conversations Conversation[]
  buyerSearches BuyerSearch[]
  purchases     Negotiation[] @relation("BuyerNegotiations")
  sales         Negotiation[] @relation("SellerNegotiations")
  sessions      Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A product the user wants to sell. The seller's pricing flexibility is
// captured as natural language rather than hidden numeric reservation fields.
model Product {
  id                  String   @id @default(uuid())
  userId              String
  conversationId      String?  @unique
  title               String
  description         String
  category            String?
  condition           String?
  askPrice            Float
  negotiationStrategy String?
  imageUrl            String?
  status              String   @default("active") // active | sold | withdrawn
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id])
  conversation Conversation?     @relation(fields: [conversationId], references: [id])
  embedding    ProductEmbedding?
  negotiations Negotiation[]

  @@index([userId])
  @@index([status])
  @@index([category])
}

model ProductEmbedding {
  id        String                 @id @default(uuid())
  productId String                 @unique
  embedding Unsupported("vector(1536)")
  text      String
  model     String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// What a buyer is looking for. maxPrice is still a hard buyer budget; the
// strategy field captures how strict or urgent the buyer feels about it.
model BuyerSearch {
  id                  String   @id @default(uuid())
  buyerId             String
  conversationId      String?  @unique
  query               String
  requirements        String?
  category            String?
  maxPrice            Float
  negotiationStrategy String?
  timeBudgetSeconds   Int      @default(120)
  imageUrl            String?
  imageDescription    String?
  status              String   @default("collecting")
    // collecting | ready | running | completed | failed
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  buyer        User                @relation(fields: [buyerId], references: [id])
  conversation Conversation?        @relation(fields: [conversationId], references: [id])
  negotiations Negotiation[]
  jobs         Job[]

  @@index([buyerId])
  @@index([status])
  @@index([category])
}

// Generic onboarding conversation. mode is "buying" or "posting_product".
model Conversation {
  id        String   @id @default(uuid())
  userId    String
  mode      String
  status    String   @default("in_progress") // in_progress | completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product?
  search   BuyerSearch?
  messages ConversationMessage[]

  @@index([userId])
  @@index([mode])
  @@index([status])
}

model ConversationMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // user | assistant | system
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// One negotiation = one (search, product) pair worked through by two LLM agents.
// A successful negotiation is the deal record.
model Negotiation {
  id          String    @id @default(uuid())
  searchId    String
  productId   String
  buyerId     String
  sellerId    String
  status      String    @default("pending")
    // pending | running | accepted | rejected | timed_out | error
  successful  Boolean   @default(false)
  finalPrice  Float?
  reason      String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  search   BuyerSearch          @relation(fields: [searchId], references: [id])
  product  Product              @relation(fields: [productId], references: [id])
  buyer    User                 @relation("BuyerNegotiations", fields: [buyerId], references: [id])
  seller   User                 @relation("SellerNegotiations", fields: [sellerId], references: [id])
  messages NegotiationMessage[]

  @@index([searchId])
  @@index([productId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model NegotiationMessage {
  id            String   @id @default(uuid())
  negotiationId String
  side          String   // "seller" | "buyer"
  action        String   // "offer" | "counter" | "accept" | "reject" | "open"
  proposedPrice Float?
  content       String
  createdAt     DateTime @default(now())

  negotiation Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@index([negotiationId])
}

// Background job tracking for async match+negotiate runs.
model Job {
  id        String   @id @default(uuid())
  type      String   // "run_search"
  status    String   @default("queued")
    // queued | running | succeeded | failed
  searchId  String?
  payload   String   @default("{}")
  result    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  search BuyerSearch? @relation(fields: [searchId], references: [id])
}
