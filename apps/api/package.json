{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "seed": "tsx src/scripts/seed-from-fb.ts",
    "scrape:fb": "tsx src/scripts/scrape-fb-marketplace.ts",
    "seed:fb": "tsx src/scripts/seed-from-fb.ts",
    "db:setup": "pnpm --filter @repo/db exec prisma db execute --file prisma/reset-demo-schema.sql && pnpm --filter @repo/db exec prisma db execute --file prisma/enable-pgvector.sql && pnpm --filter @repo/db exec prisma db push --skip-generate && pnpm --filter @repo/db exec prisma generate && pnpm --filter @repo/db exec prisma db execute --file prisma/product-embedding-index.sql"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.14.0",
    "@repo/db": "workspace:*",
    "@repo/logger": "workspace:*",
    "@types/multer": "^2.1.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "openai": "^6.37.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.24",
    "@types/uuid": "^11.0.0",
    "playwright": "^1.48.0",
    "prisma": "^5.14.0",
    "tsup": "^8.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
