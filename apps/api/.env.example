# Required: your Gemini API key (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional: pin a specific Gemini model (default gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# SQLite path. Use an ABSOLUTE path so the seed and runtime both find the same file.
# Example for this repo:
DATABASE_URL=file:/absolute/path/to/repo/packages/db/prisma/dev.db

PORT=4000
