# Choose the LLM provider: openai or gemini.
# If omitted, the API uses OpenAI when OPENAI_API_KEY is set, otherwise Gemini.
LLM_PROVIDER=openai

# Required when LLM_PROVIDER=openai (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Optional: pin a specific model (default gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Optional: pin vision/image descriptions (default gpt-4o-mini)
OPENAI_VISION_MODEL=gpt-4o-mini
# Optional: timeout for downloading remote images before LLM vision calls.
VISION_IMAGE_FETCH_TIMEOUT_MS=15000

# Required when LLM_PROVIDER=gemini (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-key-here

# Optional: pin a specific model (default gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Minimum cosine similarity required before a product can be matched to a search.
MIN_MATCH_SIMILARITY=0.3

# MercadoLibre API access token (https://developers.mercadolibre.com.ar/devcenter).
# Required for /sites/MLA/search calls used by onboarding price refs.
MERCADOLIBRE_ACCESS_TOKEN=APP_USR-...

# PostgreSQL database. Matches the local Docker Compose service at the repo root.
DATABASE_URL=postgresql://marketplace:marketplace@localhost:5432/marketplace?schema=public

PORT=4000
WEB_ORIGIN=http://localhost:3000

# Facebook Marketplace scraper options.
FB_LOCATION=buenosaires
FB_MAX_PER_CAT=150
# FB_CATEGORIES=vehicles,electronics,apparel,home-goods,musical-instruments,sporting-goods,toys-games
