# Required: your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Optional: pin a specific model (default gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# SQLite path. Use an ABSOLUTE path so the seed and runtime both find the same file.
DATABASE_URL=file:/absolute/path/to/repo/packages/db/prisma/dev.db

PORT=4000
